{
  "name": "khala",
  "version": "0.1.0",
  "description": "Single self-learning developer agent package for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "gitagent"
  ],
  "license": "MIT",
  "scripts": {
    "smoke": "npm run lint",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write ."
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-subagents/skills",
      "./node_modules/pi-lens/skills"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "@ff-labs/pi-fff": "^0.6.4",
    "get-shit-done-cc": "^1.40.0",
    "js-yaml": "^4.1.1",
    "pi-lens": "^3.8.40",
    "pi-subagents": "^0.17.5",
    "pi-thinking-steps": "^1.0.8"
  },
  "bundledDependencies": [
    "@ff-labs/pi-fff",
    "get-shit-done-cc",
    "pi-subagents",
    "pi-thinking-steps",
    "pi-lens"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/js-yaml": "^4.0.9",
    "prettier": "3.8.3"
  }
}
